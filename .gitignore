# Frontend (React Native/Expo)
# =========================
# Dependencies & Build files
frontend/node_modules/
frontend/.expo/

# Build and crash logs
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/expo-debug.log*

