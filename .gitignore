# =========================
# Backend (Python/Django)
# =========================
# Virtual Environment
backend/env/

# Database & Cache
backend/db.sqlite3
backend/__pycache__/
backend/chat/__pycache__/
*.pyc

# Security, Tokens & Credentials (CRITICAL)
backend/.env
backend/credentials.json
backend/mcp_tokens/
env
.env
# Temporary / Log files
backend/tmp/
backend/chat/tmp/

# If you don't need npm in the backend, ignore these
backend/node_modules/
backend/package-lock.json

